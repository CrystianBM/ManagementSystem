@page "/products"
@inject ProductApiService Api
@using ManagementSystem.Client.Models
@using ManagementSystem.Client.Services

@rendermode InteractiveWebAssembly

<h1>Products</h1>


@if (products == null)
{
    <p>Loading...</p>
}
else
{
    <input class="form-control w-25 mt-4 mb-4" placeholder="Filter by name..." @bind="filter" @bind:event="oninput" />

    <table class="w-50">

        <tr>
            <th>Product Name</th>
            <th>Price</th>
            <th>Stock</th>

            <th colspan="2" style="text-align: center">Actions</th>
        </tr>

        @foreach (var p in PaginatedProducts)
        {
            <tr>
                <td style="width: 10vw">@p.Name</td> 
                <td style="width: 10vw">R$ @p.Price</td>
                <td style="width: 10vw">Estoque: @p.Stock</td>
                    
                <td style="display: flex; justify-content: center;">
                    <button class="btn btn-warning m-2" @onclick="() => Edit(p)">Edit</button>
                    <button class="btn btn-danger m-2" @onclick="() => Delete(p.Id)">Delete</button>
                </td>
            </tr>
        }
    </table>

    <div class="mt-4 mb-4">
        <button class="btn btn-primary btn-sm me-3" @onclick="PrevPage" disabled="@(currentPage == 1)">Back</button>

        <span> Page @currentPage of @TotalPages </span>

        <button class="btn btn-primary btn-sm ms-3" @onclick="NextPage" disabled="@(currentPage == TotalPages)">Next</button>
    </div>

    <hr />

    <h4>@(editing ? "Edit Product" : "New Product")</h4>

    <div class="input-group mb-2">
        <span class="input-group-text" style="width: 8vw">Product</span>
        <input class="form-control w-25" placeholder="Name" @bind="form.Name" />
    </div>
    <div class="input-group mb-2">
        <span class="input-group-text" style="width: 8vw">SKU</span>
        <input class="form-control w-25" placeholder="Ex: SKU001" @bind="form.SKU" />
    </div>
    <div class="input-group mb-2">
        <span class="input-group-text" style="width: 8vw">Price (R$)</span>
        <input class="form-control w-25" type="number" placeholder="R$100.00" @bind="form.Price" />
    </div>
    <div class="input-group mb-2">
        <span class="input-group-text" style="width: 8vw">Stock</span>
        <input class="form-control w-25" type="number" placeholder="0" @bind="form.Stock" />
    </div>
    <div class="input-group">
        <span class="input-group-text" style="width: 8vw">Category</span>
        <input class="form-control w-25" placeholder="Ex: Accessories" @bind="form.Category" />
    </div>

    <br />

    @if (editing)
    {
        <button class="btn btn-success" @onclick="Update">Save</button>
        <button class="btn btn-danger" @onclick="Cancel">Cancel</button>
    }
    else
    {
        <button class="btn btn-primary" @onclick="Create">Add</button>
    }

    <hr />

}

@code {
    private List<ProductDto> products;

    private ProductDto form = new();
    private bool editing = false;

    private string filter = "";

    // PAGINAÇÃO
    private int currentPage = 1;
    private int pageSize = 10;

    private IEnumerable<ProductDto> FilteredProducts =>
        string.IsNullOrWhiteSpace(filter)
            ? products
            : products.Where(p => p.Name.Contains(filter, StringComparison.OrdinalIgnoreCase));

    private int TotalPages =>
        (int)Math.Ceiling(FilteredProducts.Count() / (double)pageSize);

    private IEnumerable<ProductDto> PaginatedProducts =>
        FilteredProducts
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize);

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        products = await Api.Get();
        currentPage = 1;
    }

    private async Task Create()
    {
        await Api.Create(form);
        form = new ProductDto();
        await Load();
    }

    private void Edit(ProductDto p)
    {
        form = new ProductDto
        {
            Id = p.Id,
            Name = p.Name,
            SKU = p.SKU,
            Price = p.Price,
            Stock = p.Stock,
            Category = p.Category
        };

        editing = true;
    }

    private async Task Update()
    {
        await Api.Update(form);
        form = new ProductDto();
        editing = false;
        await Load();
    }

    private void Cancel()
    {
        form = new ProductDto();
        editing = false;
    }

    private async Task Delete(Guid id)
    {
        await Api.Delete(id);
        await Load();
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
            currentPage++;
    }

    private void PrevPage()
    {
        if (currentPage > 1)
            currentPage--;
    }
}